# Hyperliquid Credentials
HYPERLIQUID_WALLET_ADDRESS=0xYourWalletAddressHere
HYPERLIQUID_API_PRIVATE_KEY=0xYourPrivateKeyHere

# Anthropic API (for Claude-powered analysis)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Telegram Notifications
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# Network: "testnet" or "mainnet"
NETWORK=testnet

# Mainnet safety lock — set to "true" only when you're ready to trade real funds
CONFIRM_MAINNET=

# Initial bankroll in USD
INITIAL_BANKROLL=1000
